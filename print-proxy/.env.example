PORT=3000

# BIND_HOST controls which network interface the proxy listens on.
# 127.0.0.1  — secure default (loopback only, not reachable from the network)
# 0.0.0.0    — use ONLY inside Docker/container networking where the host is
#              isolated by the container network itself and firewalled externally.
# Never expose the print proxy directly to the public internet.
BIND_HOST=127.0.0.1

# API key protecting the /print endpoint.
# Generate with: openssl rand -hex 32
# Must match PRINT_PROXY_KEY in backend/.env
PRINT_PROXY_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Printer whitelist — only printers listed here can be targeted.
# Use internal LAN IPs only. Never expose printer ports externally.
# Format: JSON array of {name, host, port}
PRINTERS_JSON=[{"name":"kitchen","host":"192.168.1.50","port":9100},{"name":"counter","host":"192.168.1.51","port":9100}]

# NODE_ENV controls /health verbosity.
# In production, /health returns only {"status":"ok"}.
# In development, it also returns version, uptime, and printer count.
NODE_ENV=production
