APP_NAME="Bake & Grill"
APP_ENV=local
APP_KEY=   # IMPORTANT: Generate with `php artisan key:generate`
# IMPORTANT: Set APP_DEBUG=false in production — true exposes stack traces publicly.
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
# Use LOG_LEVEL=warning or error in production to avoid logging sensitive request data.
LOG_LEVEL=debug

# ── Database ─────────────────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
# Docker Compose uses PostgreSQL 15 — keep DB_CONNECTION=pgsql for consistency.
# For local non-Docker development you may switch to mysql and DB_PORT=3306.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=bakegrill
DB_USERNAME=bakegrill
DB_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true   # Required for HTTPS deployments
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=   # Set a strong random password for production
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@bakeandgrill.mv"
MAIL_FROM_NAME="${APP_NAME}"

# ── Print Proxy ───────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -hex 32
PRINT_PROXY_URL=http://127.0.0.1:3000
PRINT_PROXY_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── Dhiraagu SMS ──────────────────────────────────────────────────────────────
# Required for OTP and promotional SMS. Do not commit real credentials.
DHIRAAGU_API_URL=https://messaging.dhiraagu.com.mv/v1/api/sms
DHIRAAGU_SMS_USERNAME=CHANGE_ME_DHIRAAGU_USERNAME
DHIRAAGU_SMS_PASSWORD=CHANGE_ME_DHIRAAGU_PASSWORD

# ── Frontend URLs (CORS allowlist) ────────────────────────────────────────────
# Restrict to your actual domains in production. Do not use wildcards (*).
FRONTEND_URL=http://localhost:3003
POS_URL=http://localhost:3001
KDS_URL=http://localhost:3002

# ── BML Connect Payment Gateway ───────────────────────────────────────────────
# Real credentials provided by Bank of Maldives. Never commit real values.
# Webhook secret: generate with openssl rand -hex 32 and register in BML dashboard.
BML_BASE_URL=https://api.merchants.bankofmaldives.com.mv
BML_APP_ID=CHANGE_ME_BML_APP_ID
BML_API_KEY=CHANGE_ME_BML_API_KEY
BML_MERCHANT_ID=CHANGE_ME_BML_MERCHANT_ID
BML_WEBHOOK_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
BML_RETURN_URL="${APP_URL}/payments/bml/return"
FRONTEND_ORDER_STATUS_URL=https://app.bakeandgrill.mv/orders
BML_DEFAULT_CURRENCY=MVR
BML_ENVIRONMENT=production

# ── Promotions ────────────────────────────────────────────────────────────────
PROMO_CODE_CASE_INSENSITIVE=true

# ── Tax ───────────────────────────────────────────────────────────────────────
TAX_RATE_BP=0
TAX_INCLUSIVE=false

# ── Loyalty Program ───────────────────────────────────────────────────────────
LOYALTY_ENABLED=true
LOYALTY_EARN_RATE=1
LOYALTY_REDEEM_RATE=100
LOYALTY_MIN_REDEEM=100
LOYALTY_MAX_REDEEM=10000
LOYALTY_MAX_REDEEM_PERCENT=50
LOYALTY_HOLD_TTL=30
LOYALTY_TIERS_ENABLED=false

# ── Xero OAuth 2.0 ───────────────────────────────────────────────────────────
# OAuth credentials from https://developer.xero.com
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://yourapp.com/api/xero/callback
XERO_REVENUE_ACCOUNT=200
XERO_EXPENSE_ACCOUNT=400
XERO_BANK_ACCOUNT=090

# ── Stripe Payment Gateway ────────────────────────────────────────────────────
# Keys from https://dashboard.stripe.com
# Webhook secret: generate in Stripe dashboard under Webhooks.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Web Push (VAPID) Notifications ───────────────────────────────────────────
# Generate keys: php artisan push:generate-vapid
# Add the public key to online-order-web as VITE_VAPID_PUBLIC_KEY
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ── Real-time SSE ─────────────────────────────────────────────────────────────
# Set to true to use Redis pub/sub for SSE instead of DB polling (lower latency)
# Requires Redis server and REDIS_HOST to be configured above.
REALTIME_USE_REDIS=false
